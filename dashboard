<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MediFlow System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        /* === RESET & GLOBAL === */
        body { font-family: 'Segoe UI', sans-serif; transition: background-color 0.3s; margin: 0; padding: 0; }
        .view-section { display: none; }
        .view-section.active { display: block; animation: fadeIn 0.5s; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* =========================================
           1. PASIEN UI (Clean Minimalist Style)
           Sesuai Screenshot: Kotak Merah & Kotak Biru Lebar
        ========================================= */
        .bg-pasien-theme { background-color: #fcfcfd; } /* Latar belakang putih/abu sangat muda */
        
        .new-sidebar { 
            width: 80px; 
            height: 100vh; 
            background: #ffffff; 
            position: fixed; 
            left: 0; 
            top: 0; 
            border-right: 1px solid #eaeaea; 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            padding: 30px 0; 
            z-index: 100;
        }
        .new-sidebar .nav-icon { 
            font-size: 1.5rem; 
            color: #adb5bd; 
            margin-bottom: 35px; 
            cursor: pointer; 
            transition: 0.3s;
        }
        .new-sidebar .nav-icon.active { color: #0d6efd; }
        .new-sidebar .nav-icon.text-danger { color: #dc3545 !important; }
        .avatar-circle {
            width: 40px; height: 40px; 
            background-color: #cce5ff; 
            border-radius: 50%; 
            display: flex; align-items: center; justify-content: center; 
            font-weight: bold; color: #0056b3; margin-top: auto;
        }

        .new-main { 
            margin-left: 80px; 
            padding: 50px; 
            min-height: 100vh;
        }

        /* Desain Kotak Merah (Cek Kesehatan) */
        .card-health-check {
            border: 3px solid #dc3545;
            border-radius: 20px;
            background: #ffffff;
            padding: 50px 30px;
            text-align: center;
            height: 100%;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            transition: transform 0.3s;
        }
        .card-health-check:hover { transform: translateY(-5px); }

        /* Desain Kotak Biru (Nomor Antrean) */
        .card-queue {
            background: #1a73e8; /* Biru terang solid */
            border-radius: 20px;
            padding: 50px 40px;
            color: #ffffff;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            box-shadow: 0 10px 25px rgba(26, 115, 232, 0.3);
            transition: transform 0.3s;
        }
        .card-queue:hover { transform: translateY(-5px); }
        .card-queue .queue-number { font-size: 6rem; font-weight: 800; line-height: 1.1; margin: 10px 0; }

        .btn-outline-custom { border: 1px solid #ccc; color: #333; border-radius: 50px; padding: 8px 25px; transition: 0.3s; background: white; }
        .btn-outline-custom:hover { background: #f8f9fa; border-color: #bbb; }


        /* =========================================
           2. DOKTER UI (Alisha Style - Dark Blue)
        ========================================= */
        .bg-doc-theme { background-color: #f4f6fc; }
        .d-sidebar { width: 90px; height: 96vh; background: #3b5998; position: fixed; left: 20px; top: 2vh; border-radius: 30px; text-align: center; padding: 30px 0; color: white; }
        .d-main { margin-left: 130px; padding: 30px; margin-right: 350px; }
        .d-right { width: 330px; height: 96vh; background: transparent; position: fixed; right: 20px; top: 2vh; padding: 10px; overflow-y: auto; }
        .d-banner { background: #4a69bd; border-radius: 20px; padding: 40px; color: white; display: flex; align-items: center; justify-content: space-between; }
        .d-card { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.03); margin-bottom: 20px; }

        /* =========================================
           3. ADMIN UI (Crextio Style - Frosty Blue)
        ========================================= */
        .bg-admin-theme { background-color: #e6f0fa; }
        .a-container { padding: 40px; max-width: 1400px; margin: 0 auto; }
        .a-topnav { background: white; border-radius: 30px; padding: 10px 30px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 30px; }
        .a-card { background: white; border-radius: 25px; padding: 25px; box-shadow: 0 10px 20px rgba(0,0,0,0.02); height: 100%; }
        .bpjs-check-box { background: #f8fbff; border: 2px dashed #b8cde0; border-radius: 15px; padding: 20px; }
    </style>
</head>
<body>

    <div id="viewPasien" class="view-section">
        <div class="new-sidebar">
            <div class="nav-icon active"><i class="bi bi-grid-fill"></i></div>
            <div class="nav-icon"><i class="bi bi-calendar"></i></div>
            <div class="nav-icon text-danger"><i class="bi bi-heart-pulse-fill"></i></div>
            <div class="nav-icon"><i class="bi bi-journal-medical"></i></div>
            <div class="nav-icon"><i class="bi bi-box-arrow-right"></i></div>
            
            <div class="avatar-circle">US</div>
        </div>

        <div class="new-main">
            <div class="d-flex justify-content-between align-items-center mb-5">
                <div>
                    <h1 class="fw-bold mb-1">Halo, Ahmad Dhani</h1>
                    <p class="text-muted mb-0">Pasien Rawat Jalan</p>
                </div>
                <button class="btn btn-outline-custom" onclick="window.location.href='index.html'">Logout</button>
            </div>

            <div class="row g-4">
                <div class="col-md-5 col-lg-4">
                    <div class="card-health-check">
                        <i class="bi bi-heart-pulse-fill text-danger mb-3 d-block" style="font-size: 3.5rem;"></i>
                        <h5 class="fw-bold text-dark mb-2">Cek Kesehatan</h5>
                        <p class="text-muted mb-4 small">Tekanan Darah: 120/80 mmHg</p>
                        <span class="badge bg-success px-4 py-2 rounded-pill fw-normal fs-6">Normal</span>
                    </div>
                </div>

                <div class="col-md-7 col-lg-8">
                    <div class="card-queue">
                        <p class="mb-0 fw-semibold opacity-75 fs-5">Nomor Antrean Anda</p>
                        <div class="queue-number">A-14</div>
                        <p class="mb-0 fs-5">Poli Umum - dr. Sinta</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="viewDokter" class="view-section">
        <div class="d-sidebar">
            <div class="fs-4 mb-5"><i class="bi bi-capsule"></i></div>
            <div class="fs-4 mb-4 opacity-50"><i class="bi bi-house"></i></div>
            <div class="fs-4 mb-4"><i class="bi bi-calendar-week"></i></div>
            <div class="fs-4 mb-4 opacity-50"><i class="bi bi-people"></i></div>
            <a href="index.html" class="text-white mt-5 d-block"><i class="bi bi-box-arrow-left"></i></a>
        </div>

        <div class="d-main">
            <div class="d-banner mb-4">
                <div>
                    <h2 class="fw-bold">Good Day, Dr. Nicholls!</h2>
                    <p class="mb-0 opacity-75">Have a Nice Monday!</p>
                </div>
                <img src="https://cdni.iconscout.com/illustration/premium/thumb/female-doctor-4433606-3684347.png" width="100">
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-4"><div class="d-card text-center"><h2 class="text-danger">27</h2><p class="small text-muted mb-0">Offline Patients</p></div></div>
                <div class="col-md-4"><div class="d-card text-center"><h2 class="text-success">9</h2><p class="small text-muted mb-0">Online Consults</p></div></div>
                <div class="col-md-4"><div class="d-card text-center"><h2 class="text-primary">19</h2><p class="small text-muted mb-0">Lab Analysis</p></div></div>
            </div>

            <div class="d-card">
                <h6 class="fw-bold mb-3">My Plans Done</h6>
                <div class="mb-2 small">Consultations <div class="progress mt-1" style="height: 6px;"><div class="progress-bar bg-primary" style="width: 64%"></div></div></div>
                <div class="mb-2 small">Analysis <div class="progress mt-1" style="height: 6px;"><div class="progress-bar bg-danger" style="width: 50%"></div></div></div>
            </div>
        </div>

        <div class="d-right">
            <div class="d-card text-center mb-3">
                <img src="https://ui-avatars.com/api/?name=Alisha&background=2c5af3&color=fff" class="rounded-circle mb-2" width="60">
                <h6 class="fw-bold mb-0">Dr. Alisha Nicholls</h6>
                <p class="small text-muted mb-3">Dermatologist</p>
                <div class="d-flex justify-content-between small text-muted bg-light p-2 rounded">
                    <span>Blood: A(II)</span> <span>Hours: 9am - 5pm</span>
                </div>
            </div>

            <div class="d-card">
                <h6 class="fw-bold mb-3">April 13 (Today)</h6>
                <ul class="list-unstyled small text-muted">
                    <li class="mb-3"><b class="text-dark">2:00 pm</b> - Meet with Dr. Williams</li>
                    <li class="mb-3"><b class="text-dark">2:30 pm</b> - Consult with Mr. White</li>
                    <li class="mb-3"><b class="text-dark">3:00 pm</b> - Consult with Mrs. Maisy</li>
                </ul>
            </div>
        </div>
    </div>

    <div id="viewAdmin" class="view-section">
        <div class="a-container">
            <div class="a-topnav shadow-sm">
                <h4 class="fw-bold text-primary mb-0">MediFlow Admin</h4>
                <div class="d-flex gap-4 small fw-bold text-muted">
                    <span class="text-primary">Dashboard</span>
                    <span>Registrasi</span>
                    <span>Kamar</span>
                </div>
                <a href="index.html" class="btn btn-sm btn-outline-danger rounded-pill">Logout</a>
            </div>

            <h2 class="fw-bold mb-4">Welcome in, Admin</h2>

            <div class="row g-4">
                <div class="col-md-4">
                    <div class="a-card text-center bg-primary text-white">
                        <img src="https://ui-avatars.com/api/?name=Admin&background=fff&color=000" class="rounded-circle mb-3" width="80">
                        <h5>Admin Registrasi</h5>
                        <p class="small opacity-75">Tugas: Verifikasi Data & BPJS</p>
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="a-card">
                        <h5 class="fw-bold mb-3">Pengecekan Data Pasien & BPJS</h5>
                        <div class="bpjs-check-box">
                            <div class="row g-2 mb-3">
                                <div class="col-8"><input type="text" id="inputNik" class="form-control" placeholder="Masukkan NIK Pasien..."></div>
                                <div class="col-4"><button onclick="cekBpjs()" class="btn btn-primary w-100">Cek Data</button></div>
                            </div>
                            
                            <div id="hasilCek" class="d-none mt-3 p-3 bg-white rounded shadow-sm border">
                                <h6 class="fw-bold">Hasil Verifikasi: Budi Santoso</h6>
                                <p class="small text-danger fw-bold mb-1"><i class="bi bi-x-circle"></i> BPJS Tidak Aktif (Menunggak 3 Bulan)</p>
                                <p class="small text-muted mb-3">Pasien tidak dapat menggunakan layanan BPJS.</p>
                                <button class="btn btn-warning btn-sm fw-bold w-100" onclick="alert('Status diubah! Pasien dialihkan ke pendaftaran UMUM (Berbayar).')">
                                    Alihkan ke Pasien Umum
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="a-card">
                        <h5 class="fw-bold mb-3">September 2026</h5>
                        <div class="d-flex justify-content-between small text-muted text-center bg-light p-3 rounded">
                            <span>Mon<br>22</span><span>Tue<br>23</span><span class="text-primary fw-bold">Wed<br>24</span><span>Thu<br>25</span><span>Fri<br>26</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Router Role
        const params = new URLSearchParams(window.location.search);
        const role = params.get('role');

        if(role === 'pasien') {
            document.body.className = 'bg-pasien-theme';
            document.getElementById('viewPasien').classList.add('active');
        } else if(role === 'dokter') {
            document.body.className = 'bg-doc-theme';
            document.getElementById('viewDokter').classList.add('active');
        } else if(role === 'admin') {
            document.body.className = 'bg-admin-theme';
            document.getElementById('viewAdmin').classList.add('active');
        } else {
            // Jika dibuka tanpa role, tampilkan pasien sebagai default untuk testing
            document.body.className = 'bg-pasien-theme';
            document.getElementById('viewPasien').classList.add('active');
        }

        // Fungsi Admin: Cek BPJS dan Opsi Umum
        function cekBpjs() {
            const nik = document.getElementById('inputNik').value;
            if(nik === '') {
                alert('Masukkan NIK terlebih dahulu!');
                return;
            }
            document.getElementById('hasilCek').classList.remove('d-none');
        }
    </script>
</body>
</html>